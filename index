<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Figma to AI Video Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .drop-active { border: 2px dashed #4F46E5 !important; background-color: #EEF2FF !important; }
        .figma-layer { position: absolute; pointer-events: none; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b px-8 py-4 flex justify-between items-center shadow-sm">
        <h1 class="text-xl font-bold text-gray-800 flex items-center gap-2">
            <span class="text-indigo-600">❖</span> Figma Motion Studio
        </h1>
        <button class="bg-indigo-600 text-white px-6 py-2 rounded-lg font-bold hover:bg-indigo-700 transition">
            Export Video
        </button>
    </nav>

    <main class="max-w-[1400px] mx-auto p-8 grid grid-cols-12 gap-8">
        
        <aside class="col-span-3 space-y-6">
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 space-y-4">
                <h2 class="font-bold text-gray-800 flex items-center gap-2 border-b pb-2">
                    ⚙️ API Settings
                </h2>
                <div>
                    <label class="text-[11px] font-bold text-gray-400 uppercase">Figma Access Token</label>
                    <input type="password" id="figma-token" 
                           class="w-full mt-1 p-2 text-sm border rounded bg-gray-50 focus:ring-2 focus:ring-indigo-500 outline-none transition" 
                           placeholder="figd_...">
                </div>
                <div>
                    <label class="text-[11px] font-bold text-gray-400 uppercase">Gemini API Key</label>
                    <input type="password" id="gemini-key" 
                           class="w-full mt-1 p-2 text-sm border rounded bg-gray-50 focus:ring-2 focus:ring-indigo-500 outline-none transition" 
                           placeholder="AIzaSy...">
                </div>
                <button onclick="saveApiKeys()" class="w-full bg-indigo-100 text-indigo-700 py-2 rounded-lg text-sm font-bold hover:bg-indigo-200 transition">
                    Save Keys
                </button>
                <p id="save-msg" class="text-[10px] text-center text-green-500 hidden font-bold">✓ Keys saved safely!</p>
            </div>

            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 space-y-4">
                <h2 class="font-bold text-gray-800 border-b pb-2">🎬 Motion Control</h2>
                <div>
                    <label class="text-xs text-gray-500 uppercase font-bold">Motion Intensity</label>
                    <input type="range" id="motion-range" class="w-full mt-2 accent-indigo-600">
                </div>
                <div>
                    <label class="text-xs text-gray-500 uppercase font-bold">Gemini Prompt Assist</label>
                    <textarea id="ai-prompt" class="w-full border rounded-lg p-3 text-sm mt-2 bg-gray-50 outline-none focus:ring-2 focus:ring-indigo-500" rows="4" 
                              placeholder="제미나이가 이미지를 분석하여 최적의 영상 프롬프트를 제안합니다."></textarea>
                </div>
            </div>
        </aside>

        <section class="col-span-6 flex flex-col items-center">
            <h2 class="font-bold text-gray-700 mb-4 self-start">Canvas Preview</h2>
            <div id="drop-zone" class="relative w-full max-w-[400px] aspect-[9/16] bg-white shadow-2xl rounded-2xl overflow-hidden flex items-center justify-center border-4 border-dashed border-gray-200 transition-all cursor-pointer hover:border-indigo-300">
                
                <div id="bg-preview" class="absolute inset-0 bg-gray-100 flex items-center justify-center transition-all">
                    <div class="text-center p-6">
                        <div class="text-4xl mb-2 text-gray-300">📸</div>
                        <p class="text-gray-400 text-sm leading-relaxed font-medium">
                            배경으로 쓰일 이미지를<br><span class="text-indigo-500 font-bold underline">이곳에 드래그 앤 드롭</span> 하세요.
                        </p>
                    </div>
                </div>

                <div id="figma-overlay" class="absolute inset-0 z-10 pointer-events-none">
                    <div class="figma-layer top-[15%] left-0 right-0 text-center">
                        <h3 class="text-4xl font-black text-white drop-shadow-[0_4px_4px_rgba(0,0,0,0.5)] tracking-tighter italic">NEW COLLECTION</h3>
                        <p class="text-white text-sm font-bold opacity-90">2026 SPRING / SUMMER</p>
                    </div>
                    <div class="figma-layer bottom-12 left-10 right-10">
                        <div class="bg-white text-black py-4 text-center font-black rounded-full shadow-xl">SHOP NOW</div>
                    </div>
                </div>

                <div id="loader" class="hidden absolute inset-0 z-20 bg-black/70 flex flex-col items-center justify-center text-white backdrop-blur-sm">
                    <div class="animate-spin rounded-full h-14 w-14 border-4 border-indigo-400 border-t-transparent mb-4"></div>
                    <p class="font-bold animate-pulse text-indigo-200">AI가 영상을 생성 중입니다...</p>
                    <p class="text-[10px] mt-2 opacity-60">Gemini & Video AI Processing</p>
                </div>
            </div>
        </section>

        <aside class="col-span-3 space-y-6">
            <h2 class="font-bold text-gray-700 border-b pb-2">Select Template</h2>
            <div class="space-y-3">
                <div class="p-4 bg-indigo-600 rounded-xl shadow-lg border-2 border-indigo-400 cursor-pointer text-white">
                    <p class="text-xs opacity-80 uppercase font-bold">Mobile Portrait</p>
                    <p class="text-lg font-black">Insta Story Style</p>
                </div>
                <div class="p-4 bg-white rounded-xl shadow-sm border border-gray-200 cursor-pointer hover:border-indigo-400 transition group">
                    <p class="text-xs text-gray-400 uppercase font-bold group-hover:text-indigo-400">Square</p>
                    <p class="text-lg font-black text-gray-700 group-hover:text-indigo-600">Feed Post Style</p>
                </div>
            </div>

            <div class="bg-amber-50 p-4 rounded-xl border border-amber-100">
                <p class="text-xs text-amber-800 leading-relaxed">
                    <strong>💡 사용 팁:</strong> 배경 이미지를 넣으면 Gemini가 사진을 분석해 최적의 움직임을 설정합니다. 결과물은 MP4 영상으로 생성됩니다.
                </p>
            </div>
        </aside>

    </main>

    <script>
        const dropZone = document.getElementById('drop-zone');
        const bgPreview = document.getElementById('bg-preview');
        const loader = document.getElementById('loader');
        const saveMsg = document.getElementById('save-msg');

        // 페이지 로드 시 기존 API 키 불러오기
        window.onload = () => {
            document.getElementById('figma-token').value = localStorage.getItem('figma_token') || '';
            document.getElementById('gemini-key').value = localStorage.getItem('gemini_key') || '';
        };

        // API 키 로컬 스토리지에 저장
        function saveApiKeys() {
            localStorage.setItem('figma_token', document.getElementById('figma-token').value);
            localStorage.setItem('gemini_key', document.getElementById('gemini-key').value);
            saveMsg.classList.remove('hidden');
            setTimeout(() => saveMsg.classList.add('hidden'), 2000);
        }

        // 드래그 앤 드롭 이벤트
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('drop-active');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('drop-active');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('drop-active');
            
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    // 1. 이미지를 배경에 즉시 표시
                    bgPreview.innerHTML = `<img src="${event.target.result}" class="w-full h-full object-cover">`;
                    
                    // 2. AI 프로세스 시작 (시뮬레이션)
                    processAI(event.target.result);
                };
                reader.readAsDataURL(file);
            } else {
                alert("이미지 파일만 업로드 가능합니다.");
            }
        });

        function processAI(imageData) {
            loader.classList.remove('hidden');
            
            // 시뮬레이션: 3초 후 완료
            setTimeout(() => {
                loader.classList.add('hidden');
                // 실제 연동 시: 여기서 Gemini API 호출 -> 프롬프트 획득 -> Runway/Luma API 호출 순서로 진행
                alert("배경 분석이 완료되었습니다. 이제 'Export Video'를 눌러 영상을 생성할 수 있습니다.");
                document.getElementById('ai-prompt').value = "분석 결과: 이 이미지는 풍경화입니다. 구름이 오른쪽에서 왼쪽으로 천천히 흐르고 햇살이 일렁이는(Shimmering) 모션을 추천합니다.";
            }, 3000);
        }
    </script>
</body>
</html>
