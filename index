<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Figma to AI Video Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .drop-active { border: 2px dashed #4F46E5; background-color: #EEF2FF; }
        .figma-layer { position: absolute; pointer-events: none; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b px-8 py-4 flex justify-between items-center">
        <h1 class="text-xl font-bold text-gray-800">Figma Motion Studio</h1>
        <button class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">Export Video</button>
    </nav>

    <main class="max-w-7xl mx-auto p-8 grid grid-cols-12 gap-8">
        
<aside class="col-span-3 space-y-6 overflow-y-auto max-h-[80vh] pr-2">
    
    <div class="bg-indigo-50 p-4 rounded-xl border border-indigo-100 space-y-4">
        <h2 class="font-bold text-indigo-900 flex items-center gap-2">
            ⚙️ API Settings
        </h2>
        
        <div>
            <label class="text-[11px] font-bold text-indigo-400 uppercase">Figma Access Token</label>
            <input type="password" id="figma-token" 
                   class="w-full mt-1 p-2 text-sm border rounded bg-white focus:ring-2 focus:ring-indigo-500 outline-none" 
                   placeholder="figd_...">
        </div>

        <div>
            <label class="text-[11px] font-bold text-indigo-400 uppercase">Gemini API Key</label>
            <input type="password" id="gemini-key" 
                   class="w-full mt-1 p-2 text-sm border rounded bg-white focus:ring-2 focus:ring-indigo-500 outline-none" 
                   placeholder="AIzaSy...">
        </div>

        <button onclick="saveApiKeys()" class="w-full bg-indigo-500 text-white py-2 rounded-lg text-sm font-bold hover:bg-indigo-600 transition">
            Save Keys
        </button>
        <p id="save-msg" class="text-[10px] text-center text-indigo-400 hidden">Keys saved to local storage!</p>
    </div>

    <hr class="border-gray-200">

    <div class="space-y-4">
        <h2 class="font-semibold text-gray-700">🎬 Motion Control</h2>
        <div>
            <label class="text-xs text-gray-500 uppercase">Motion Intensity</label>
            <input type="range" class="w-full mt-1 accent-indigo-600">
        </div>
        <div>
            <label class="text-xs text-gray-500 uppercase">Gemini Prompt Assist</label>
            <textarea id="ai-prompt" class="w-full border rounded-lg p-2 text-sm mt-1" rows="3" 
                      placeholder="제미나이가 이미지 분석 후 모션 프롬프트를 추천해줍니다."></textarea>
        </div>
    </div>
</aside>

        <section class="col-span-6">
            <h2 class="font-semibold text-gray-700 mb-4">2. Canvas (Drag & Drop Background)</h2>
            <div id="drop-zone" class="relative w-full aspect-[9/16] bg-white shadow-2xl rounded-xl overflow-hidden flex items-center justify-center border-2 border-transparent transition-all">
                
                <div id="bg-preview" class="absolute inset-0 bg-gray-100 flex items-center justify-center">
                    <p class="text-gray-400 text-center px-10">드래그해서 배경 이미지를 넣어주세요.<br>(AI가 자동으로 영상을 생성합니다)</p>
                </div>

                <div id="figma-overlay" class="absolute inset-0 z-10">
                    <div class="figma-layer top-1/4 left-10 text-4xl font-black text-white drop-shadow-lg">SUMMER<br>SALE</div>
                    <div class="figma-layer bottom-10 left-10 right-10 py-3 bg-white text-black text-center font-bold rounded">SHOP NOW</div>
                </div>

                <div id="loader" class="hidden absolute inset-0 z-20 bg-black/50 flex flex-col items-center justify-center text-white">
                    <div class="animate-spin rounded-full h-12 w-12 border-4 border-indigo-500 border-t-transparent mb-4"></div>
                    <p>AI가 영상을 생성 중입니다...</p>
                </div>
            </div>
        </section>

        <aside class="col-span-3 space-y-6">
            <h2 class="font-semibold text-gray-700">3. AI Motion Settings</h2>
            <div class="space-y-4">
                <div>
                    <label class="text-xs text-gray-500 uppercase">Motion Intensity</label>
                    <input type="range" class="w-full mt-1">
                </div>
                <div>
                    <label class="text-xs text-gray-500 uppercase">Style Prompt</label>
                    <textarea class="w-full border rounded-lg p-2 text-sm mt-1" rows="3" placeholder="예: 구름이 천천히 움직이는 느낌"></textarea>
                </div>
            </div>
        </aside>

    </main>

    <script>
        const dropZone = document.getElementById('drop-zone');
        const bgPreview = document.getElementById('bg-preview');
        const loader = document.getElementById('loader');

        dropZone.ondragover = (e) => {
            e.preventDefault();
            dropZone.classList.add('drop-active');
        };

        dropZone.ondragleave = () => {
            dropZone.classList.remove('drop-active');
        };

        dropZone.ondrop = (e) => {
            e.preventDefault();
            dropZone.classList.remove('drop-active');
            
            // 1. 이미지 파일 감지
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    // 배경을 업로드한 이미지로 변경
                    bgPreview.innerHTML = `<img src="${event.target.result}" class="w-full h-full object-cover">`;
                    
                    // 2. AI 변환 시뮬레이션
                    startAIProcess();
                };
                reader.readAsDataURL(file);
            }
        };

        function startAIProcess() {
            loader.classList.remove('hidden');
            // 여기에 실제 Backend API (Runway, Luma 등) 호출 로직이 들어갑니다.
            setTimeout(() => {
                loader.classList.add('hidden');
                alert("AI 영상 변환이 완료되었습니다! (시뮬레이션)");
                // 실제로는 bgPreview에 생성된 <video> 태그를 넣게 됩니다.
            }, 3000);
        }
    </script>
</body>
</html>
